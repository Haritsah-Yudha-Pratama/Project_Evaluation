Options -Indexes
Require all granted

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^api/(.*)$ api/index.php/$1 [QSA,L]
</IfModule>

<FilesMatch "\.(sql|md|env)$">
    Require all denied
</FilesMatch>
